        private void Form1_Load(object sender, EventArgs e)
        {
            try
            {
                // Reset RNG provider on each load by reseeding the PRNG from CSPRNG
                try
                {
                    byte[] seedBytes = new byte[4];
                    using (var rng = RandomNumberGenerator.Create())
                    {
                        rng.GetBytes(seedBytes);
                    }
                    int seed = BitConverter.ToInt32(seedBytes, 0);
                    ran = new Random(seed);
                }
                catch { ran = new Random(); }
                NUchars = File.ReadAllText("CharsMap\\number.ini", Encoding.UTF8);
                Nchars = File.ReadAllText("CharsMap\\normal.ini", Encoding.UTF8);
                Schars = File.ReadAllText("CharsMap\\special.ini", Encoding.UTF8);
                Echars = File.ReadAllText("CharsMap\\enabled.ini", Encoding.UTF8);

                labelStatus.Text = settings.LoadData(false);
                waitTime = (settings.requestMode) ? settings.requestDelay : 100;
                apikey = settings.key;

                numericUpDownLenght.Value = settings.lenght;

                switch (settings.mode)
                {
                    case 0: radTypeNumbers.Checked = true; break;
                    case 1: radTypeCharNormal.Checked = true; break;
                    case 2: radTypeCharSpecial.Checked = true; break;
                    case 3: radTypeCharEnabled.Checked = true; break;
                    case 4: radTypeCharAll.Checked = true; break;
                }

                radTypeGenLocal.Checked = !settings.usedApi;
                radTypeGenOnline.Checked = settings.usedApi;
                checkBoxClear.Checked = settings.clearPreviusResult;
                checkBoxCopy.Checked = settings.copyToClibboard;
            }
            catch (Exception ex) { MessageBox.Show(ex.ToString()); }
        }

        private async void buttonGenerate_Click(object sender, EventArgs e)
        {
            string tmp = "internal error";
            labelStatus.Text = "Wait a MINUTE, Please.";
            maxlenght = (int)numericUpDownLenght.Value;

            if (radTypeNumbers.Checked) mode = 0;
            else if (radTypeCharNormal.Checked) mode = 1;
            else if (radTypeCharSpecial.Checked) mode = 2;
            else if (radTypeCharEnabled.Checked) mode = 3;
            else if (radTypeCharAll.Checked) mode = 4;

            usedApi = radTypeGenOnline.Checked;

            if (usedApi)
                tmp = await rorgGen();
            else
                tmp = localGen();
            if (checkBoxCopy.Checked)//copy clip
                Clipboard.SetText(tmp);
            if (checkBoxClear.Checked)//clear result
                textBoxResult.Clear();
            errors = (tmp.Split("\n")[0] == "0") ? tmp.Split("\n")[2] : "OK";
            textBoxResult.Text += tmp.Replace("0\n", "");
            labelStatus.Text = errors + "\nChars generated: " + tmp.Length.ToString();
        }

